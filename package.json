{
  "name": "arttburger",
  "productName": "ArttBurger",
  "private": true,
  "version": "1.2.5",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "postinstall": "patch-package",
    "electron:dev": "cross-env NODE_ENV=development electron .",
    "electron:build": "node scripts/create-icon.cjs && cross-env BUILD_TARGET=electron vite build && electron-packager . ArttBurger --platform=win32 --arch=x64 --out=dist-electron --overwrite --electron-version=31.7.7 --icon=src/assets/logo.ico --ignore=\"(node_modules|\\.git|\\.claude|android|arttburger-bot|src|dist-electron)\" --ignore-locales=af,am,ar,bg,bn,ca,cs,da,de,el,en-GB,es,es-419,et,fa,fi,fil,fr,gu,he,hi,hr,hu,id,it,ja,kn,ko,lt,lv,ml,mr,ms,nb,nl,pl,pt-PT,ro,ru,sk,sl,sr,sv,sw,ta,te,th,tr,uk,ur,vi,zh-CN,zh-TW",
    "release": "node scripts/release.cjs"
  },
  "dependencies": {
    "@capacitor-community/background-geolocation": "^1.2.26",
    "@capacitor-community/keep-awake": "^8.0.1",
    "@capacitor/android": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@capacitor/geolocation": "^8.2.0",
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.12.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-leaflet": "^5.0.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.4",
    "@electron/packager": "^20.0.0",
    "@types/express": "^4.17.21",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.21",
    "cross-env": "^7.0.3",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "patch-package": "^8.0.1",
    "png-to-ico": "^3.0.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^5.4.21",
    "vite-plugin-pwa": "^1.3.0"
  },
  "build": {
    "appId": "com.arttburger.sistema",
    "productName": "ArttBurger",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "directories": {
      "output": "dist-electron"
    },
    "win": {
      "target": "dir",
      "icon": "src/assets/logo.png",
      "signingHashAlgorithms": null,
      "sign": null
    }
  }
}
